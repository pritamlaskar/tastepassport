# ============================================================
# TastePassport — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Required ---
# Anthropic API key for entity extraction and enrichment
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Database ---
# Format: postgresql://user:password@host:port/dbname
# When running via docker-compose this is pre-configured
DATABASE_URL=postgresql://tastepassport:password@postgres:5432/tastepassport

# --- Redis ---
# When running via docker-compose this is pre-configured
REDIS_URL=redis://redis:6379/0

# --- Pipeline Tuning ---
# Number of days before a city is considered stale and re-crawled
CRAWL_RECRAWL_DAYS=7

# Seconds to wait between Reddit API requests (respect rate limits)
REDDIT_DELAY_SECONDS=2

# Maximum number of blog posts to scrape per city crawl
MAX_BLOG_SOURCES_PER_CITY=25

# Minimum upvotes for a Reddit thread to be included
MIN_REDDIT_UPVOTES=10

# Minimum LocalScore for a place to appear in results (0-100)
MIN_LOCAL_SCORE=25

# Minimum number of distinct mentions for a place to appear in results
MIN_MENTIONS=2

# Only index Reddit posts from the last N days (0 = no limit, not recommended)
# 90 days keeps results relevant and cuts crawl time significantly
REDDIT_RECENCY_DAYS=90

# Only fetch comments for Reddit posts with at least this many upvotes.
# Low-upvote posts rarely add restaurant signal worth the extra API requests.
REDDIT_COMMENT_FETCH_MIN_UPVOTES=50

# --- Reddit API (required) ---
# The public Reddit JSON API blocks datacenter IPs with 403.
# OAuth access is free and unlimited for read-only use.
#
# How to get credentials (takes 2 minutes):
#   1. Go to https://www.reddit.com/prefs/apps
#   2. Click "create another app" at the bottom
#   3. Name it "tastepassport", select "script", redirect URI = http://localhost:8080
#   4. Copy the client_id (under the app name) and client_secret
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
# Format: "platform:app_name:version (by /u/your_reddit_username)"
REDDIT_USER_AGENT=script:tastepassport:v1.0 (by /u/your_reddit_username)

# --- Environment ---
# Options: development, production
ENVIRONMENT=development

# ============================================================
# Marketing Agent (optional — only needed for marketing/)
# ============================================================

# TastePassport API base URL (default: http://localhost:8000)
TP_API_URL=http://localhost:8000

# Comma-separated city slugs to generate content for daily
# Leave blank to auto-select top 3 indexed cities
TARGET_CITIES=

# Twitter/X API (for direct posting — optional)
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Instagram Graph API (for direct posting — optional)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# LinkedIn API (for direct posting — optional)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_ID=
